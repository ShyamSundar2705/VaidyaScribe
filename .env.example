# ─── Copy to .env and fill in values ─────────────────────────────

# App
DEBUG=false
SECRET_KEY=change-this-to-a-random-64-char-string-in-production

# ─── Database ─────────────────────────────────────────────────────
# Local (default):
DATABASE_URL=sqlite+aiosqlite:///./data/vaidyascribe.db

# AWS RDS PostgreSQL (free tier — db.t3.micro, 750hrs/month):
# DATABASE_URL=postgresql+asyncpg://vaidyascribe:yourpassword@your-rds-endpoint.ap-south-1.rds.amazonaws.com:5432/vaidyascribe

# ─── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Ollama ───────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b

# ─── Groq (strongly recommended — free at console.groq.com) ───────
GROQ_API_KEY=
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ─── AWS S3 (free tier — 5GB storage) ─────────────────────────────
# Leave empty to use local file storage (default)
# Create IAM user with S3FullAccess, generate access key
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=

# ─── QA + burnout ─────────────────────────────────────────────────
QA_CONFIDENCE_THRESHOLD=0.70
BURNOUT_HOURS_THRESHOLD=10.0
BURNOUT_NOTES_THRESHOLD=50
