# ─── Copy to .env — all tools are free, no payment required ──────

# App
DEBUG=true
SECRET_KEY=change-me-in-production

# Ollama (local LLM — runs on your laptop, free)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b

# Groq — free tier fallback (no credit card needed)
# Get free key at: https://console.groq.com
# Leave empty to use Ollama only
GROQ_API_KEY=
USE_GROQ_FALLBACK=false

# Whisper model size — "medium" for speed on CPU, "large-v3" for accuracy
WHISPER_MODEL=medium
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Redis (local Docker, free)
REDIS_URL=redis://redis:6379/0

# Database (SQLite, serverless, free)
DATABASE_URL=sqlite+aiosqlite:///./data/vaidyascribe.db
LANCEDB_URI=./data/lancedb

# QA safety threshold — below this forces human doctor review
QA_CONFIDENCE_THRESHOLD=0.85

# Burnout alert thresholds
BURNOUT_HOURS_THRESHOLD=10.0
BURNOUT_NOTES_THRESHOLD=50
